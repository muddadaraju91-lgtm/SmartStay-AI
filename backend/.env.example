PORT=5000
NODE_ENV=development
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=smartstay_db
DB_PORT=3306
# REQUIRED — minimum 32 characters. Generate a safe value with:
#   openssl rand -hex 32
# Never commit a real secret here. Set this in your deployment environment variables.
JWT_SECRET=
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Booking Expiry Configuration
# How many minutes a pending booking may sit before it is auto-cancelled
# and its held vacancy slot is released (default: 30).
BOOKING_EXPIRY_MINUTES=30
# How often the background expiry sweep runs, in milliseconds (default: 600000 = 10 min).
BOOKING_EXPIRY_INTERVAL_MS=600000

# Cloudinary Credentials (For image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay Credentials (For payments processing)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Rate Limiting
# Auth endpoints (/api/auth/login, /api/auth/register) — strict brute-force guard.
# AUTH_RATE_MAX requests allowed per AUTH_RATE_WINDOW_MS milliseconds per IP.
# Tighten in production (e.g. MAX=5, WINDOW=900000).
AUTH_RATE_WINDOW_MS=900000
AUTH_RATE_MAX=10

# General API limiter — applied to all other /api/* routes.
# API_RATE_MAX requests allowed per API_RATE_WINDOW_MS milliseconds per IP.
API_RATE_WINDOW_MS=900000
API_RATE_MAX=300

# Recommendation Engine Performance
# Radius (km) of the SQL Haversine pre-filter applied before JS scoring.
# Increase if your hostels spread across a wider area; keep small for dense cities.
RECOMMENDATION_CANDIDATE_KM=25
# How long (ms) the pre-filtered candidate set is cached per coordinate bucket.
# Set to 0 to disable caching (useful in tests). Default: 60000 (60 s).
HOSTEL_CACHE_TTL_MS=60000
